#!/usr/bin/env bash
set -euo pipefail

script_dir="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
script_name="$(basename "${BASH_SOURCE[0]}")"

info() {
    echo "[$script_name] $@"
}

error() {
    echo "[$script_name] $@" 1>&2
}

die() {
    error "$@"
    exit 1
}

overlay_home="${script_dir}/_home"
container_home="/root"
container_opts=()

common_opts() {
    container_opts+=(-h "$HOSTNAME"
        --network host
        -e LANG
        -e GTK_IM_MODULE=xim -e QT_IM_MODULE=xim -e XMODIFIERS
    )
}

home_opts() {
    mkdir -p "$overlay_home"
    container_opts+=(-v "$overlay_home:$container_home")
    if [[ -e "$HOME/.local/share/fonts" ]]; then
        container_opts+=(-v "$HOME/.local/share/fonts:$container_home/.local/share/fonts:ro")
    fi
}

x11_opts() {
    container_opts+=(-e DISPLAY -v /tmp/.X11-unix:/tmp/.X11-unix)
    if [[ -e "$HOME/.Xauthority" ]]; then
        container_opts+=(-v "$HOME/.Xauthority:$container_home/.Xauthority:ro")
    fi
}

container-run() {
    common_opts
    home_opts
    x11_opts

    info "Running container with options: ${container_opts[*]} $*"
    podman run "${container_opts[@]}" "$@"
}


mllab() {
    container_opts+=(-v "$PWD:$PWD" -w "$PWD")
    container_opts+=(-ti --rm --gpus all -e NVIDIA_DRIVER_CAPABILITIES=all)
    if [[ -d "/usr/share/vulkan/icd.d" ]]; then
        container_opts+=(-v "/usr/share/vulkan/icd.d:/usr/share/vulkan/icd.d:ro")
    fi
    
    container-run ghcr.io/yc-gao/ml:latest "$@"
}

jupyter() {
    container_opts+=(-v "$PWD:$PWD" -w "$PWD")
    container_opts+=(-ti --rm --gpus all -e NVIDIA_DRIVER_CAPABILITIES=all)
    if [[ -d "/usr/share/vulkan/icd.d" ]]; then
        container_opts+=(-v "/usr/share/vulkan/icd.d:/usr/share/vulkan/icd.d:ro")
    fi

    container-run ghcr.io/yc-gao/ml:latest \
        jupyter lab --allow-root --no-browser --NotebookApp.token='' "$@"
}

main() {
    case "$script_name" in
        mllab)
            mllab "$@"
            ;;
        jupyter)
            jupyter "$@"
            ;;
        *)
            die "Unknown command: $script_name"
            ;;
    esac
}

main "$@"